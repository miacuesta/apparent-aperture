---
import Layout from "../layouts/Layout.astro"
import Card from "../components/Card.astro"
---

<Layout>

<button id="menuBtn" class="menu-btn">⚙</button>

<div id="sideMenu" class="side-menu">

  <h3>Opciones</h3>

  <button id="darkModeBtn">🌙 Modo oscuro</button>
  <button id="clearBtn">🗑 Borrar tareas</button>
  <button id="completeAllBtn">✔ Marcar todas</button>

</div>

<main>

<header>
  <h1>Mi lista de tareas</h1>
</header>

<Card>
  <h2>Agregar tarea</h2>
  <input id="taskInput" type="text" placeholder="Escribe una tarea">
  <button id="addBtn">Agregar</button>
</Card>

<Card>
  <h2>Tareas</h2>
  <ul id="taskList"></ul>
</Card>

<Card>
  <h2>Sobre la app</h2>
  <p>Esta app permite organizar tareas.</p>
</Card>

</main>

</Layout>